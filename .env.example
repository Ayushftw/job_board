# Database
DATABASE_URL="postgresql://user:password@localhost:5432/jobtrackr?schema=public"

# Auth (NextAuth v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# AI
GEMINI_API_KEY=""

# File Storage (UploadThing)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Email (Resend)
# Use onboarding@resend.dev for testing (only sends to your Resend account email).
# To email recruiters, verify a domain at https://resend.com/domains then set:
# RESEND_FROM_EMAIL="JobTrackr <outreach@yourdomain.com>"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="JobTrackr <onboarding@resend.dev>"

# Caching + Queue (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Monitoring (Sentry - optional)
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"
